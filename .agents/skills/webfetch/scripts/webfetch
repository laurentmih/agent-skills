#!/bin/bash
# Portable wrapper for the webfetch skill

# Get the absolute path of the directory containing this script
SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_PYTHON="$SKILL_DIR/.venv/bin/python3"
PYTHON_SCRIPT="$SKILL_DIR/webfetch.py"

# Check if the virtual environment exists
if [[ ! -f "$VENV_PYTHON" ]]; then
    echo "Error: Virtual environment not found at $VENV_PYTHON" >&2
    echo "Please create it by running the following commands:" >&2
    echo "  cd \"$SKILL_DIR\"" >&2
    echo "  python3 -m venv .venv" >&2
    echo "  ./.venv/bin/pip install -r requirements.txt" >&2
    exit 1
fi

# Execute the Python script using the local venv
exec "$VENV_PYTHON" "$PYTHON_SCRIPT" "$@"
